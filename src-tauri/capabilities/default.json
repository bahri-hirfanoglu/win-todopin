{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for TodoPin windows",
  "windows": ["manager", "card-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "autostart:default",
    "global-shortcut:default",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
