{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "TodoPin",
  "version": "0.4.0",
  "identifier": "com.todopin.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:14200",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "manager",
        "title": "TodoPin",
        "url": "index.html",
        "width": 420,
        "height": 600,
        "minWidth": 380,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3NURGOTEyNjE5MTBCMjcKUldRbkM1RmhFdmxkRjVIL1Rib3FBN0d3WXdWbnZjK08vY0E5NGJqakFWWEtiTngrYUpnM21NUm4K",
      "endpoints": [
        "https://github.com/bahri-hirfanoglu/win-todopin/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
